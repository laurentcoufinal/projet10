<Row><Cell ss:StyleID="Header"><Data ss:Type="String">Couche</Data></Cell><Cell ss:StyleID="Header"><Data ss:Type="String">Thème</Data></Cell><Cell ss:StyleID="Header"><Data ss:Type="String">Constat</Data></Cell><Cell ss:StyleID="Header"><Data ss:Type="String">Lien backlog</Data></Cell></Row>
<Row><Cell><Data ss:Type="String">Front Angular</Data></Cell><Cell><Data ss:Type="String">Zoneless + Signals</Data></Cell><Cell><Data ss:Type="String">Angular 20.2+ · moins de change detection</Data></Cell><Cell><Data ss:Type="String">US-1, US-10</Data></Cell></Row>
