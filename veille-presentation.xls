<Row><Cell><Data ss:Type="String">Front Angular</Data></Cell><Cell><Data ss:Type="String">NgOptimizedImage</Data></Cell><Cell><Data ss:Type="String">Lazy-load images satellite · réduit CLS</Data></Cell><Cell><Data ss:Type="String">Imagerie</Data></Cell></Row>
<Row><Cell><Data ss:Type="String">Back Spring</Data></Cell><Cell><Data ss:Type="String">N+1 / OSIV</Data></Cell><Cell><Data ss:Type="String">open-in-view=false · JOIN FETCH · DTO</Data></Cell><Cell><Data ss:Type="String">US-9</Data></Cell></Row>
