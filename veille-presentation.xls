<Row><Cell><Data ss:Type="String">Géospatial</Data></Cell><Cell><Data ss:Type="String">Index spatial MySQL</Data></Cell><Cell><Data ss:Type="String">Sans index = full scan</Data></Cell><Cell><Data ss:Type="String">US9-T2</Data></Cell></Row>
